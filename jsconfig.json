{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "target": "es2022",
    "resolveJsonModule": true
  },
  "include": [
    "builders/**/*.js",
    "components/**/*.js",
    "hooks/**/*.js",
    "lib/**/*.js",
    "plugins/**/*.js",
    "renderers/**/*.js",
    "sources/**/*.js",
    "tasks/**/*.js",
    "utils/**/*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
